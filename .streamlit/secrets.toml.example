# Copy these into the Streamlit Community Cloud "Secrets" box (App → Settings →
# Secrets), or into a local ".streamlit/secrets.toml" (which is gitignored).
#
# A deployed app can't reach your local/cloud Ollama, so use Groq (an API key).

# Password gate — only people with this password can open the app.
APP_PASSWORD = "choose-a-strong-password"

# LLM provider: use Groq when deployed.
LLM_PROVIDER = "groq"
OPENAI_BASE_URL = "https://api.groq.com/openai/v1"
OPENAI_API_KEY = "gsk_your_groq_key_here"
OPENAI_MODEL = "llama-3.3-70b-versatile"

# Embeddings (small, runs on CPU).
EMBEDDING_MODEL = "all-MiniLM-L6-v2"
