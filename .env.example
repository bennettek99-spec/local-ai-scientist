# Copy this file to ".env" and adjust as needed. All values are optional;
# sensible defaults are used when a variable is omitted.

# ===== LLM PROVIDER =====
# "ollama" -> local or Ollama Cloud (uses the Ollama section below).
# "groq"/"gemini"/"openrouter"/"openai" -> OpenAI-compatible section further down.
LLM_PROVIDER=ollama

# ----- Ollama / Granite -----
# Base URL of your local Ollama server.
OLLAMA_HOST=http://localhost:11434
# Model tag exactly as shown by `ollama list`. Use a "-cloud" tag (e.g.
# gpt-oss:120b-cloud) for fast Ollama Cloud inference, or a local tag like
# granite4.1:3b for fully-offline use.
OLLAMA_MODEL=granite4.1:3b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TIMEOUT=1200
OLLAMA_NUM_CTX=8192

# ----- OpenAI-compatible provider (used when LLM_PROVIDER is groq/gemini/etc.) -----
# Groq (free, very fast): https://console.groq.com/keys
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.3-70b-versatile
# Gemini alternative (free tier): https://aistudio.google.com/apikey
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   OPENAI_MODEL=gemini-2.0-flash

# ----- Embeddings / retrieval -----
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=6

# ----- Search defaults -----
MAX_RESULTS_PER_FIELD=10
SEARCH_LOOKBACK_DAYS=7

# ----- Processing -----
MAX_CONCURRENT_JOBS=2
MAX_CHARS_FOR_SUMMARY=24000

# ----- Paths & logging (override only if you want data elsewhere) -----
# DATA_DIR=data
# LOGS_DIR=logs
LOG_LEVEL=INFO
